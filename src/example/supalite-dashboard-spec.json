{
   "root": "shell",
   "elements": {
      "shell": {
         "type": "StudioShell",
         "props": {
            "projectName": "Supalite PoC 123",
            "databaseName": "sl3",
            "branchName": "main",
            "environment": "STAGING",
            "statusLabel": "SELF-HOSTED",
            "navItems": [
               {
                  "id": "home",
                  "label": "Home",
                  "icon": "home"
               },
               {
                  "id": "table",
                  "label": "Table Editor",
                  "icon": "table-2"
               },
               {
                  "id": "sql",
                  "label": "SQL Editor",
                  "icon": "terminal"
               },
               {
                  "id": "auth",
                  "label": "Authentication",
                  "icon": "key-round"
               },
               {
                  "id": "storage",
                  "label": "Storage",
                  "icon": "folder"
               },
               {
                  "id": "settings",
                  "label": "Project Settings",
                  "icon": "settings"
               }
            ],
            "activeSection": {
               "$bindState": "/activeSection"
            }
         },
         "children": ["home", "table", "sql", "auth", "storage", "settings"]
      },
      "home": {
         "type": "Stack",
         "visible": {
            "$state": "/activeSection",
            "eq": "home"
         },
         "props": {
            "direction": "vertical",
            "gap": "lg",
            "align": "stretch",
            "justify": "start",
            "className": "min-w-0 flex-1 overflow-auto bg-background p-8"
         },
         "children": ["home-title", "home-connect", "home-stats"]
      },
      "home-title": {
         "type": "Stack",
         "props": {
            "direction": "vertical",
            "gap": "sm",
            "className": "max-w-6xl"
         },
         "children": ["home-heading", "home-copy"]
      },
      "home-heading": {
         "type": "Heading",
         "props": {
            "text": "sl3",
            "level": "h1"
         },
         "children": []
      },
      "home-copy": {
         "type": "Text",
         "props": {
            "text": "A lightweight Supabase-compatible backend. Postgres, Auth and Storage, nothing more.",
            "variant": "muted"
         },
         "children": []
      },
      "home-connect": {
         "type": "Card",
         "props": {
            "title": "Connect",
            "description": "Project URL and anon key.",
            "maxWidth": "full",
            "centered": false,
            "className": "max-w-6xl bg-card"
         },
         "children": ["home-url", "home-key"]
      },
      "home-url": {
         "type": "Text",
         "props": {
            "text": "https://sl3.supalite.app",
            "variant": "code"
         },
         "children": []
      },
      "home-key": {
         "type": "Text",
         "props": {
            "text": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsInNpZCI6InNsM2FhYjhkOSJ9.fVgK3w...",
            "variant": "code"
         },
         "children": []
      },
      "home-stats": {
         "type": "Grid",
         "props": {
            "columns": 4,
            "gap": "md",
            "className": "max-w-6xl"
         },
         "children": ["stat-tables", "stat-users", "stat-buckets", "stat-db"]
      },
      "stat-tables": {
         "type": "Card",
         "props": {
            "title": "Tables",
            "description": "5",
            "maxWidth": "full"
         },
         "children": []
      },
      "stat-users": {
         "type": "Card",
         "props": {
            "title": "Users",
            "description": "5",
            "maxWidth": "full"
         },
         "children": []
      },
      "stat-buckets": {
         "type": "Card",
         "props": {
            "title": "Buckets",
            "description": "3",
            "maxWidth": "full"
         },
         "children": []
      },
      "stat-db": {
         "type": "Card",
         "props": {
            "title": "DB Size",
            "description": "24 MB",
            "maxWidth": "full"
         },
         "children": []
      },
      "table": {
         "type": "StudioTableEditor",
         "visible": {
            "$state": "/activeSection",
            "eq": "table"
         },
         "props": {
            "schemas": {
               "$state": "/schemas"
            },
            "tablesBySchema": {
               "$state": "/tablesBySchema"
            },
            "rowsByTable": {
               "$state": "/rowsByTable"
            },
            "schema": {
               "$bindState": "/table/schema"
            },
            "activeTable": {
               "$bindState": "/table/activeTable"
            },
            "openTabs": {
               "$bindState": "/table/openTabs"
            },
            "filter": {
               "$bindState": "/table/filter"
            },
            "editingRow": {
               "$bindState": "/table/editingRow"
            }
         },
         "children": []
      },
      "sql": {
         "type": "StudioCodePanel",
         "visible": {
            "$state": "/activeSection",
            "eq": "sql"
         },
         "props": {
            "title": "Daily active users",
            "code": "select\n  date_trunc('day', last_sign_in_at) as day,\n  count(*) as users\nfrom auth.users\nwhere last_sign_in_at is not null\ngroup by 1\norder by 15555 desc;",
            "templates": [
               "Create table",
               "Add RLS policy",
               "Top tables by size"
            ],
            "savedQueries": ["Daily active users", "Orphan rows"]
         },
         "children": []
      },
      "auth": {
         "type": "StudioAuthPanel",
         "visible": {
            "$state": "/activeSection",
            "eq": "auth"
         },
         "props": {
            "section": {
               "$bindState": "/auth/section"
            },
            "search": {
               "$bindState": "/auth/search"
            },
            "selectedUserId": {
               "$bindState": "/auth/selectedUserId"
            },
            "users": {
               "$state": "/authUsers"
            }
         },
         "children": []
      },
      "storage": {
         "type": "StudioStorageExplorer",
         "visible": {
            "$state": "/activeSection",
            "eq": "storage"
         },
         "props": {
            "bucket": {
               "$bindState": "/storage/bucket"
            },
            "selectedFileName": {
               "$bindState": "/storage/selectedFileName"
            },
            "buckets": {
               "$state": "/buckets"
            },
            "filesByBucket": {
               "$state": "/filesByBucket"
            }
         },
         "children": []
      },
      "settings": {
         "type": "Stack",
         "visible": {
            "$state": "/activeSection",
            "eq": "settings"
         },
         "props": {
            "direction": "vertical",
            "gap": "md",
            "className": "min-w-0 flex-1 overflow-auto bg-background p-8"
         },
         "children": ["settings-heading", "settings-card"]
      },
      "settings-heading": {
         "type": "Heading",
         "props": {
            "text": "Project Settings",
            "level": "h2"
         },
         "children": []
      },
      "settings-card": {
         "type": "Card",
         "props": {
            "title": "General",
            "description": "Project name: sl3 / Project ID: eygxbmggewdwkztnncsw",
            "maxWidth": "full",
            "centered": false,
            "className": "max-w-3xl bg-card"
         },
         "children": []
      }
